# Generated local extraction/context artifacts may contain proprietary project details.
# Keep framework prompts/scripts/docs/config templates in Git, but do not
# accidentally commit generated customer/project outputs.

# Runtime/log/cache output
atlas/logs/
atlas/runs/
atlas/tools-output/
atlas/plans/

# Deterministic extraction artifacts
atlas/source/*.json
atlas/source/*.yaml
atlas/index/*.json
atlas/index/*.yaml
atlas/payloads/*.json
atlas/payloads/*.yaml
atlas/bindings/*.json
atlas/bindings/*.yaml
atlas/runtime/*.json
atlas/runtime/*.yaml
atlas/graph/*.json
atlas/graph/*.yaml
atlas/errors/*.json
atlas/errors/*.yaml
atlas/flows/*.json
atlas/flows/*.yaml
atlas/facts/*.json
atlas/facts/*.yaml
atlas/rules/*.json
atlas/rules/*.yaml
atlas/requirements/*.json
atlas/requirements/*.yaml
atlas/testing/*.json
atlas/testing/*.yaml
atlas/audit/*.json
atlas/audit/*.yaml
atlas/change/*.json
atlas/change/*.yaml
atlas/visualizer/**/*.json
atlas/visualizer/**/*.html
atlas/visualizer/**/*.md

# Legacy/generated higher-level outputs
atlas/reviews/
atlas/knowledge/
atlas/context-packs/
atlas/domains/
atlas/global/*.yaml
atlas/global/*.json
atlas/map/*.yaml
atlas/map/*.json
atlas/code-health/
atlas/test-planning/
atlas/sample-data/
atlas/maintenance/
atlas/releases/
atlas/architecture-discovery/

# Preserve placeholder files if intentionally tracked.
!atlas/**/.gitkeep

# Local read models
atlas/codeatlas.sqlite
atlas/*.duckdb
atlas/*.kuzu

# OS/editor
.DS_Store
.vscode/
.idea/

# ngk local runtime/read-model outputs
.ngk/
*.egg-info/
__pycache__/
*.py[cod]
