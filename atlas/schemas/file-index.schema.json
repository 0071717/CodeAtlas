{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codeatlas.dev/schemas/file-index.schema.json",
  "title": "CodeAtlas File Index",
  "type": "object",
  "required": ["generated_at", "files"],
  "properties": {
    "generated_at": { "type": "string" },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "repo", "path", "language", "classification", "line_count", "size_bytes", "sha256"],
        "properties": {
          "id": { "type": "string" },
          "repo": { "type": "string" },
          "repo_role": { "type": "string" },
          "path": { "type": "string" },
          "language": { "type": "string" },
          "classification": { "type": "string" },
          "line_count": { "type": "integer", "minimum": 0 },
          "size_bytes": { "type": "integer", "minimum": 0 },
          "sha256": { "type": "string", "minLength": 64, "maxLength": 64 }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
