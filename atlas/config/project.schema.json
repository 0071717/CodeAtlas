{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CodeAtlas Project Configuration",
  "type": "object",
  "required": ["project", "repositories"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "repositories": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["id", "path"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string" },
          "path": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": [
              "frontend",
              "backend",
              "react_frontend",
              "fastapi_backend",
              "shared_contracts",
              "opensearch_config",
              "sample_data_generation",
              "test_support",
              "documentation",
              "unknown"
            ]
          },
          "role": { "type": "string" },
          "language": { "type": "string" },
          "framework": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "extraction": { "type": "object", "additionalProperties": true },
    "rules": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": true
}
