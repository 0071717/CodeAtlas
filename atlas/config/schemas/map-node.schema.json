{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codeatlas.dev/schemas/map-node.schema.json",
  "$comment": "Trust fields are enforced by record-envelope.schema.json and atlas/tools/validate_artifacts.py. This family schema validates the node-specific shape only.",
  "title": "CodeAtlasMapNode",
  "type": "object",
  "required": ["id", "type", "state", "evidence", "provenance"],
  "properties": {
    "id": {"type": "string"},
    "type": {"type": "string"},
    "repo": {"type": ["string", "null"]},
    "file": {"type": ["string", "null"]},
    "name": {"type": ["string", "null"]},
    "confidence": {"enum": ["high", "medium", "low", "none"]},
    "state": {"enum": ["verified", "inferred", "unsupported", "stale", "contradicted", "partial", "unknown"]},
    "needs_review": {"type": "boolean"},
    "evidence": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "provenance": {"type": "object", "additionalProperties": true},
    "metadata": {"type": "object"}
  },
  "additionalProperties": true
}
