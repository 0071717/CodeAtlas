{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codeatlas.dev/schemas/record-envelope.schema.json",
  "title": "CodeAtlas Record Envelope (shared trust contract)",
  "description": "The trust contract every canonical record collection must satisfy. It is enforced programmatically by atlas/tools/validate_artifacts.py in addition to each family schema, so the contract lives in exactly one place. Family schemas reference this file via a $comment. confidence is optional here (some structural collections do not carry it) but must be one of the allowed values when present; state, evidence, and provenance are always required.",
  "type": "object",
  "required": [
    "state",
    "evidence",
    "provenance"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "state": {
      "enum": [
        "verified",
        "inferred",
        "unsupported",
        "stale",
        "contradicted",
        "partial",
        "unknown"
      ]
    },
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low",
        "none"
      ]
    },
    "needs_review": {
      "type": "boolean"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "file_sha256",
          "commit_sha",
          "snippet_sha256",
          "extractor",
          "deterministic",
          "verification_status"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "repo": {
            "type": "string"
          },
          "file": {
            "type": "string"
          },
          "symbol": {
            "type": "string"
          },
          "line_start": {
            "type": "integer",
            "minimum": 1
          },
          "line_end": {
            "type": "integer",
            "minimum": 1
          },
          "commit_sha": {
            "type": [
              "string",
              "null"
            ]
          },
          "file_sha256": {
            "type": [
              "string",
              "null"
            ]
          },
          "snippet_sha256": {
            "type": [
              "string",
              "null"
            ]
          },
          "extractor": {
            "type": "string"
          },
          "deterministic": {
            "type": "boolean"
          },
          "verification_status": {
            "enum": [
              "current",
              "unresolved",
              "stale",
              "contradicted"
            ]
          },
          "metadata": {
            "type": "object"
          }
        },
        "additionalProperties": true
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "schema_version",
        "generated_at",
        "generator",
        "generator_version",
        "input_artifact_sha256",
        "source_manifest_sha256"
      ],
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "generated_at": {
          "type": "string"
        },
        "generator": {
          "type": "string"
        },
        "generator_version": {
          "type": "string"
        },
        "input_artifact": {
          "type": "string"
        },
        "input_artifact_sha256": {
          "type": "string"
        },
        "source_manifest_sha256": {
          "type": "string"
        },
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
