{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeadCodeCandidate",
  "type": "object",
  "required": [
    "id",
    "domain_id",
    "artifact_type",
    "file_path",
    "reason",
    "confidence"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "domain_id": {
      "type": "string"
    },
    "artifact_type": {
      "type": "string"
    },
    "file_path": {
      "type": "string"
    },
    "symbol_name": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "recommended_action": {
      "type": "string"
    },
    "status": {
      "type": "string"
    }
  }
}